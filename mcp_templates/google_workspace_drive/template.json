{
  "id": "google_workspace_drive",
  "display_name": "Google Workspace Drive MCP",
  "description": "Connect Google Drive MCP to read Google Docs and Drive files via OAuth2.",
  "default_server_name": "google-drive",
  "tags": [
    "google",
    "workspace",
    "drive",
    "docs",
    "oauth2",
    "hosted"
  ],
  "is_recommended": true,
  "config": {
    "transport": "http_streamable",
    "url": "https://drivemcp.googleapis.com/mcp/v1",
    "request_timeout_seconds": 30,
    "auth": {
      "mode": "oauth2",
      "authorize_url": "https://accounts.google.com/o/oauth2/v2/auth",
      "token_url": "https://oauth2.googleapis.com/token",
      "client_id": "",
      "client_secret": "",
      "redirect_uri": "http://localhost:1984/callback",
      "connect_fields": [
        {
          "key": "client_id",
          "label": "Google OAuth Client ID",
          "type": "text",
          "required": true,
          "placeholder": "1234567890-abc.apps.googleusercontent.com"
        },
        {
          "key": "client_secret",
          "label": "Google OAuth Client Secret",
          "type": "password",
          "required": true,
          "help_text": "Required for Google OAuth web clients."
        },
        {
          "key": "redirect_uri",
          "label": "OAuth Redirect URI",
          "type": "url",
          "required": true,
          "placeholder": "http://localhost:1984/callback"
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/drive.readonly",
        "https://www.googleapis.com/auth/drive.file"
      ],
      "use_pkce": true
    }
  }
}
